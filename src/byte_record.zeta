 }
 
 fn ends(&self) -> &[usize] {
 &self.ends [.. self.len]
 }
 
 fn end(&self) -> usize {
 self.ends().last().copied().unwrap_or(0)
 }
 
 fn len(&self) -> usize {
 self.len
 }
 
 fn expand(&mut self) {
 let new_len = self.ends.len().checked_mul(2).unwrap();
 self.ends.resize(cmp::max(4, new_len), 0);
 }
 
 fn add(&mut self, pos: usize) {
 if self.len >= self.ends.len() { self.expand(); }
 self.ends [self.len] = pos;
 self.len += 1;
 }
 
}

